{
  "name": "@cffnpwr/textlint-rule-preset-ja-writing-extras",
  "version": "1.0.1",
  "description": "textlintの日本語文章向けの追加ルールセット",
  "homepage": "https://github.com/cffnpwr/textlint-rule-preset-ja-writing-extras",
  "bugs": "https://github.com/cffnpwr/textlint-rule-preset-ja-writing-extras/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/cffnpwr/textlint-rule-preset-ja-writing-extras.git",
    "directory": "packages/preset-ja-writing-extras"
  },
  "license": "MIT",
  "author": "cffnpwr",
  "type": "module",
  "keywords": [
    "textlint",
    "preset"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cffnpwr/textlint-rule-no-arbitrary-line-break": "workspace:*",
    "@cffnpwr/textlint-rule-no-dash": "workspace:*",
    "@cffnpwr/textlint-rule-no-doubled-additive-conjunction": "workspace:*",
    "@cffnpwr/textlint-rule-sentence-per-line": "workspace:*"
  },
  "inlinedDependencies": {
    "@textlint/ast-node-types": "15.7.1",
    "@textlint/types": "15.7.1"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
