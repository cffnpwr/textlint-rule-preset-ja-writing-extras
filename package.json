{
  "name": "@cffnpwr/textlint-rule-preset-ja-writing-extras-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "license:sync": "bun run scripts/sync-license.ts",
    "license:check": "bun run scripts/sync-license.ts --check"
  },
  "devDependencies": {
    "@cffnpwr/eslint-config": "1.2.0",
    "@cffnpwr/tsconfig": "1.0.0",
    "@textlint/kernel": "15.7.1",
    "@textlint/textlint-plugin-markdown": "15.7.1",
    "@textlint/types": "15.7.1",
    "@types/bun": "1.3.14",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  }
}
