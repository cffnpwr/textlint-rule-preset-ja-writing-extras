{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "plugins": ["node-workspace"],
  "packages": {
    "packages/shared": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    },
    "packages/no-arbitrary-line-break": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    },
    "packages/no-dash": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    },
    "packages/no-doubled-additive-conjunction": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    },
    "packages/sentence-per-line": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    },
    "packages/preset-ja-writing-extras": {
      "extra-files": [{ "type": "json", "path": "jsr.json", "jsonpath": "$.version" }]
    }
  }
}
